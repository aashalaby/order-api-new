# Fill this in, save as scripts/bootstrap.env (gitignored — NEVER commit
# the filled-in copy), then run scripts/bootstrap-github.sh.
#
# Where each value comes from is noted inline.

# ---- Scaleway (IAM → API keys; project ID from console URL / project settings)
SCW_ACCESS_KEY=
SCW_SECRET_KEY=
SCW_PROJECT_ID=

# ---- Cloudflare (My Profile → API Tokens → "Edit zone DNS" template,
#      scoped to boozoo.top only; Zone ID from the zone overview page)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ---- Neon (connection string, pooled endpoint recommended)
DATABASE_URL=

# ---- Auth.js session-cookie key. LEAVE EMPTY to auto-generate a fresh
#      one (recommended: production must not share the key with local dev).
AUTH_SECRET=

# ---- Zitadel (project/apps/branding are Terraform-managed; only the
#      bootstrap credential and org ID are needed here)
# Organization page → copy ID
ZITADEL_ORG_ID=
# PAT of the "terraform" machine user (Org Owner) — see infra/README.md
ZITADEL_PAT=

# ---- Scaleway Container Registry namespace name (the one CI pushes to)
SCW_REGISTRY_NAMESPACE=

# ---- New Relic ingest license key. Optional: leave empty to run with
#      telemetry disabled.
NEW_RELIC_LICENSE_KEY=
