# Auth.js session-cookie encryption key. Generate with: npx auth secret
AUTH_SECRET=

# Zitadel Web application (confidential, Authorization Code + PKCE).
# Issuer = https://<your-zitadel-domain> (shown on the app detail page).
AUTH_ZITADEL_ISSUER=
AUTH_ZITADEL_ID=
AUTH_ZITADEL_SECRET=

# Zitadel project ID: adds the project-audience scope so access tokens
# carry the project in `aud` and the Go API's local JWT validation
# accepts them. Find it on the project detail page in the Zitadel console.
ZITADEL_PROJECT_ID=

# Internal URL of the Go order-api container (no trailing slash).
ORDER_API_URL=http://localhost:8080

# Base URL of THIS app, needed behind Scaleway's proxy for correct
# OAuth callback URLs (e.g. https://<web-container>.functions.fnc.nl-ams.scw.cloud)
AUTH_URL=http://localhost:3000
# Required when running behind a reverse proxy / serverless ingress.
AUTH_TRUST_HOST=true
